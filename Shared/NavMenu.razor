@inject AuthenticationStateProvider AuthenticationStateProvider
@using Microsoft.AspNetCore.Components.Authorization


<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg custom-navbar">
    <div class="container">
        <!-- ✅ MedicShifts un poco más a la derecha en responsive -->
        <a class="navbar-brand fs-3 fw-bold text-white ms-md-3" href="#">MedicShifts</a>

        <!-- ✅ Botón Hamburguesa Blanco -->
        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- MENÚ -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <a class="nav-link text-white fs-4" href="Identity/Account/Manage">
                                Hola, @context.User.Identity?.Name
                            </a>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <!-- ✅ Más separación entre Registrarse e Iniciar sesión en pantallas grandes -->
                        <li class="nav-item me-lg-3">
                            <a class="nav-link btn btn-info px-3 py-2 text-white fw-bold" href="Identity/Account/Register">Registrarse</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-light px-3 py-2 text-white fw-bold" href="Identity/Account/Login">Iniciar sesión</a>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <!-- Dropdown de Médicos -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-white fs-4" href="#" id="dropdownMedicos"
                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Médicos
                        </a>
                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="dropdownMedicos">
                            <li><a class="dropdown-item text-white fs-5" href="/editarmedico">Horarios</a></li>
                            <li><a class="dropdown-item text-white fs-5" href="/bloquearfechasmedico">Bloquear fechas</a></li>
                        </ul>
                    </li>

                    <!-- Dropdown de Turnos -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-white fs-4" href="#" id="dropdownTurnos"
                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Turnos
                        </a>
                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="dropdownTurnos">
                            <li><a class="dropdown-item text-white fs-5" href="/listarturnos">Listado de turnos</a></li>
                            <li><a class="dropdown-item text-white fs-5" href="/reservarturno">Reservar un turno</a></li>
                        </ul>
                    </li>
                </AuthorizeView>

                <AuthorizeView>
                    <Authorized>
                        @if (!isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link fs-4 text-white" href="/misturnos">Mis turnos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fs-4 text-white" href="/reservarturno">Reservar turno</a>
                            </li>
                        }

                        <li class="nav-item">
                            <form method="post" action="Identity/Account/LogOut">
                                <!-- ✅ Botón "Cerrar sesión" más angosto -->
                                <button class="btn btn-danger fs-4 px-2 mx-2" type="submit">
                                    Cerrar sesión
                                </button>
                            </form>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>


@code
{
    private bool isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAdmin = user.IsInRole("Admin");
    }
}