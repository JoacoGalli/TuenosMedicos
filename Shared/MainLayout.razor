@inherits LayoutComponentBase
@inject IJSRuntime JS
<RadzenComponents />

<NavMenu />

<main class="container">
    @Body
</main>


<footer class="site-footer">
    <div class="container">
        <div class="row">
            <!-- Sección Acerca -->
            <div class="col-md-6">
                <h6>ACERCA</h6>
                <p class="text-justify">Reserva tu turno online de manera rápida y sencilla.</p>
            </div>

            <!-- Sección Coberturas -->
            <div class="col-md-3">
                <h6>COBERTURAS</h6>
                <ul class="footer-links">
                    <li>OSDE</li>
                    <li>IOMA</li>
                    <li>Swiss Medical</li>
                </ul>
            </div>

            <!-- Sección Saber Más -->
            <div class="col-md-3">
                <h6>SABER MÁS</h6>
                <ul class="footer-links">
                    <li><a href="#">Sobre Nosotros</a></li>
                    <li><a href="/contacto/">Contáctanos</a></li>
                </ul>
            </div>
        </div>
        <hr>

        <!-- Copyright y Redes Sociales -->
        <div class="row align-items-center">
            <div class="col-md-8 text-md-start text-center">
                <p class="copyright-text">📞 No hacemos recetas por teléfono.</p>
            </div>
            <div class="col-md-4 text-md-end text-center">
                <ul class="social-icons">
                    <li><a class="facebook" href="#"><i class="fa fa-facebook"></i></a></li>
                    <li><a class="instagram" href="#"><i class="fa fa-instagram"></i></a></li>
                    <li><a class="whatsapp" href="#"><i class="fa fa-whatsapp"></i></a></li>
                </ul>
            </div>
        </div>
    </div>
</footer>



@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("attachNavbarEvents"); // Esto es para cerrar la navBar desp de hacerle click.
        }
    }
}