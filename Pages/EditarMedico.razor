@page "/editarmedico"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Edicion de medicos</PageTitle>

<h2 style="text-align: center; margin-top: 1rem; margin-bottom: 1rem;">Lista de Médicos</h2>

<RadzenRow Gap="0.5rem"
           Style="max-width: 1200px; margin: auto; display: flex; flex-wrap: wrap; justify-content: center;">

    <!-- Columna izquierda: Médicos -->
    <RadzenColumn Size="12" SizeMd="4" class="rz-p-1">
        <RadzenStack Gap="1rem" Style="align-items: stretch;">
            <RadzenListBox @bind-Value=@medicoSeleccionado Data=@medicos
                           TextProperty="NombreMedico" ValueProperty="NombreMedico"
                           Change="@OnMedicoSeleccionado"
                           Style="width: 100%; height: 250px; border-radius: 8px; border: 1px solid #ccc; padding: 10px;"
                           InputAttributes="@(new Dictionary<string,object>(){ { "aria-label", "select company" }})" />

            <RadzenButton Click=@AgregarMedico Icon="add_circle" Text="AGREGAR NUEVO MÉDICO"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="border-radius: 8px; padding: 0.5rem 1rem;" />
        </RadzenStack>
    </RadzenColumn>

    <!-- Columna derecha: Grid -->
    <RadzenColumn Size="12" SizeMd="8" class="rz-p-1">
        <RadzenStack Gap="0.5rem">
            <RadzenDataGrid @ref="ordersGrid" AllowFiltering="false" AllowPaging="true" PageSize="5" AllowSorting="true"
                            EmptyText="No hay horarios para mostrar"
                            Data="@diasYhorarios" TItem="Medico"
                            Style="width: 100%; border-radius: 8px; overflow-x: auto;">
                <Columns>
                    <RadzenDataGridColumn Property="NombreMedico" Width="120px">
                        <HeaderTemplate>
                            <RadzenIcon Icon="person" Style="margin-right: 5px;" /> Médico
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="diaTrabajo" Width="100px">
                        <HeaderTemplate>
                            <RadzenIcon Icon="event" Style="margin-right: 5px;" /> Día
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="horaInicioTrabajo" Width="110px">
                        <HeaderTemplate>
                            <RadzenIcon Icon="schedule" Style="margin-right: 5px;" /> Inicio
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="horaFinTrabajo" Width="110px">
                        <HeaderTemplate>
                            <RadzenIcon Icon="schedule" Style="margin-right: 5px;" /> Fin
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="duracionTurno" Width="130px" TextAlign="TextAlign.Center">
                        <HeaderTemplate>
                            <RadzenIcon Icon="timer" Style="margin-right: 5px;" /> Duración
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="duracionSobreTurno" Width="230px" TextAlign="TextAlign.Center">
                        <HeaderTemplate>
                            <RadzenIcon Icon="timer" Style="margin-right: 5px;" /> Duración Sobre Turno
                        </HeaderTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Context="med" Filterable="false" Sortable="false" TextAlign="TextAlign.Left" Width="90px">
                        <Template Context="med">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@(args => DeleteRow(med))" Style="border-radius: 5px;" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
            <RadzenStack Gap="1rem" JustifyContent="JustifyContent.Center">
                <RadzenButton Click=@InsertRow Text="Agregar Nuevo Horario" Icon="add" ButtonStyle="ButtonStyle.Primary" Style="border-radius: 8px; padding: 0.75rem 1.5rem;" />
            </RadzenStack>
        </RadzenStack>
    </RadzenColumn>

</RadzenRow>



@code
{
    string medicoSeleccionado = "";    

    RadzenDataGrid<Medico> ordersGrid;

    IEnumerable<Medico> medicos;

    IEnumerable<Medico> diasYhorarios;
    List<Medico> listaHorarios = new List<Medico>();

    Medico nuevoHorarioMedico = new Medico();

    DateTime horaIni = DateTime.Today.AddHours(6);
    DateTime horaFin = DateTime.Today.AddHours(23);


    protected override async Task OnInitializedAsync()
    {
        medicos = Medico.ObtenerMedicos();
        nuevoHorarioMedico.duracionSobreTurno = 0;
    }

    private bool firstRender = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (this.firstRender) // ✅ Usamos la variable de instancia
        {
            await ReloadGrid();
            this.firstRender = false; // ✅ Asegurar que solo se ejecute una vez
            StateHasChanged(); // 🔄 Forzar render para reflejar cambios en la UI
        }
    }

    private void OnMedicoSeleccionado(object value)
    {
        ReloadGrid();
    }

    async Task DeleteRow(Medico med)
    {
        var result = await DialogService.OpenAsync("Atención", ds =>
    @<RadzenStack Gap="1.5rem" Style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; text-align: center;">
        <p><RadzenIcon Icon="warning" Style="color: #dc3545; margin-right: 5px;" /> Está a punto de cancelar el horario de: <b>@med.NombreMedico</b></p>
        <p><RadzenIcon Icon="event" Style="margin-right: 5px;" /> Día: <b>@med.diaTrabajo</b></p>
        <p><RadzenIcon Icon="schedule" Style="margin-right: 5px;" /> Hora inicio: <b>@med.horaInicioTrabajo</b></p>
        <p><RadzenIcon Icon="schedule" Style="margin-right: 5px;" /> Hora fin: <b>@med.horaFinTrabajo</b></p>
        <p><b>¿Desea continuar?</b></p>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center">
            <RadzenButton Text="Confirmar" Icon="check" ButtonStyle="ButtonStyle.Danger" Click="@(args => CancelarHorario(med.Id))" />
            <RadzenButton Text="Cancelar" Icon="close" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
        </RadzenStack>
    </RadzenStack>
        );
    }


    async Task AgregarMedico()
    {
        List<string> dias = new List<string>() { "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado", "Domingo" };
        IEnumerable<string> listaDias = dias;

        var result = await DialogService.OpenAsync("Nuevo médico", ds =>
    @<RadzenStack Gap="1.5rem" Style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; max-width: 600px;">
        <p style="font-size: 1.2rem; font-weight: bold;"><RadzenIcon Icon="person_add" Style="margin-right: 5px;" /> Agregar un nuevo médico</p>

        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Nombre del médico" Style="width: 40%; font-weight: bold;" />
                <RadzenTextBox @bind-Value=medicoSeleccionado Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Día de trabajo" Style="width: 40%; font-weight: bold;" />
                <RadzenDropDown @bind-Value="nuevoHorarioMedico.diaTrabajo" Placeholder="Seleccionar un día" Data="@listaDias" Style="width: 60%;">
                    <RadzenRequiredValidator Text="Elige un día" />
                </RadzenDropDown>
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Hora inicio" Style="width: 40%; font-weight: bold;" />
                <RadzenDatePicker @bind-Value=@horaIni ShowTime="true" TimeOnly="true" DateFormat="HH:mm" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Hora fin" Style="width: 40%; font-weight: bold;" />
                <RadzenDatePicker @bind-Value=@horaFin ShowTime="true" TimeOnly="true" DateFormat="HH:mm" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Duración del turno" Style="width: 40%; font-weight: bold;" />
                <RadzenNumeric ShowUpDown="false" TValue="int" @bind-Value=@nuevoHorarioMedico.duracionTurno Placeholder="Duración" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Duración del sobre turno" Style="width: 40%; font-weight: bold;" />
                <RadzenNumeric ShowUpDown="false" TValue="int?" @bind-Value=@nuevoHorarioMedico.duracionSobreTurno Placeholder="Duración sobre turno" Style="width: 60%;" />
            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
                <RadzenButton Text="Confirmar" Icon="check" ButtonStyle="ButtonStyle.Primary" Click=InsertABase />
                <RadzenButton Text="Cancelar" Icon="close" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>
        );
    }




    async Task InsertRow()
    {
        if (!string.IsNullOrEmpty(medicoSeleccionado))
        {
            List<string> dias = new List<string>() { "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado", "Domingo" };
            IEnumerable<string> listaDias = dias;

            var result = await DialogService.OpenAsync("Nuevo horario", ds =>
    @<RadzenStack Gap="1.5rem" Style="padding: 1.5rem; max-width: 600px;">
        <p style="font-size: 1.2rem; font-weight: bold;">Crear nuevo horario para: <b>@medicoSeleccionado</b></p>

        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Día de trabajo" Style="width: 40%; font-weight: bold;" />
                <RadzenDropDown @bind-Value="nuevoHorarioMedico.diaTrabajo" Placeholder="Seleccionar un día" Data="@listaDias" Style="width: 60%;">
                    <RadzenRequiredValidator Text="Elige un día" />
                </RadzenDropDown>
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Hora inicio" Style="width: 40%; font-weight: bold;" />
                <RadzenDatePicker @bind-Value=@horaIni ShowTime="true" TimeOnly="true" DateFormat="HH:mm" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Hora fin" Style="width: 40%; font-weight: bold;" />
                <RadzenDatePicker @bind-Value=@horaFin ShowTime="true" TimeOnly="true" DateFormat="HH:mm" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Duración del turno" Style="width: 40%; font-weight: bold;" />
                <RadzenNumeric ShowUpDown="false" TValue="int" @bind-Value=@nuevoHorarioMedico.duracionTurno Placeholder="Duración" Style="width: 60%;" />
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenLabel Text="Duración del sobre turno" Style="width: 40%; font-weight: bold;" />
                <RadzenNumeric ShowUpDown="false" TValue="int?" @bind-Value=@nuevoHorarioMedico.duracionSobreTurno Placeholder="Duración Sobre Turno" Style="width: 60%;" />
            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
                <RadzenButton Text="Confirmar" Click=InsertABase ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Cancelar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>
    );
        }
        else
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Atención", Detail = "Selecciona un médico" });
        }
    }


    async Task ReloadGrid()
    {
        string query = "SELECT idMedicos,nombreMedico,diaTrabajo,horaInicioTrabajo,horaFinTrabajo,duracionTurno,duracionSobreTurno FROM medicos";

        if(!string.IsNullOrEmpty(medicoSeleccionado))
        {         
            query = query + " WHERE nombreMedico= @nombreMedico ;";
        }        

        var parametros = new Dictionary<string, object> { { "@nombreMedico", medicoSeleccionado } };

        diasYhorarios = Base.SelectAMedicos(query,parametros);
        await ordersGrid.Reload();

    }
    void InsertABase()
    {
        if (nuevoHorarioMedico.diaTrabajo != "" && nuevoHorarioMedico.duracionTurno != 0 && nuevoHorarioMedico.duracionSobreTurno != 0)
        {
            string horaInicio = horaIni.ToString("HH:mm");
            string horaFinal = horaFin.ToString("HH:mm");

            nuevoHorarioMedico.NombreMedico = medicoSeleccionado;
            nuevoHorarioMedico.horaInicioTrabajo = horaInicio;
            nuevoHorarioMedico.horaFinTrabajo = horaFinal;


            int insertarNuevohorario = Base.InsertarMedico(nuevoHorarioMedico);

            if (insertarNuevohorario == 0)
            {
                DialogService.Close(); // Cierra el diálogo
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "OK", Detail = "Horario agregado" });
                OnInitializedAsync();
                ReloadGrid();
            }
            else
            {
                Console.WriteLine("error");
            }
        }
        else
        {                    
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Atencion", Detail = "Completa todos los campos" });
        }

    }

    void CancelarHorario(int idABorrar)
    {
        string query = "DELETE FROM `medicos` WHERE idMedicos=@idMedicos;";
        var parametros = new Dictionary<string, object>{ { "@idMedicos", idABorrar } };


        int borrarFila = Base.InsertDeleteOrUpdateABase(query,parametros);
        if (borrarFila > 0)
        {
            DialogService.Close(); // Cierra el diálogo
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "OK", Detail = "Horario borrado" });
            OnInitializedAsync();
            ReloadGrid();
        }
        else
        {
            Console.WriteLine("error borrando el horario");
        }
    }
}

     