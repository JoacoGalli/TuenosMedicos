@page "/misturnos"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Serilog
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject DialogService DialogService
@inject NotificationService NotificationService


<PageTitle>Mis turnos</PageTitle>


<h2 style="text-align: center;  margin-top: 3rem; margin-bottom: 1rem;">📅 Listado de turnos reservados</h2>

<div class="rz-mb-3" style="display: flex; align-items: flex-start; justify-content: start; gap: 20px; padding: 10px 0 0 20px;">
    <RadzenLabel Text="Mostrar cancelados" Component="ButtonMostrarCancelados"
    style="font-size: 1.1rem; font-weight: bold;" />    
    <RadzenCheckBox TValue="bool" @bind-Value="mostrarCancelados" Name="ButtonMostrarCancelados" Change="@OnMostrarCanceladosChange" />

</div>

<!-- Mensaje dinámico -->
<div class="mensaje-turnos">
    @if (mostrarCancelados)
    {
        <span class="mensaje-cancelados">❌ Turnos cancelados</span>
    }
    else
    {
        <span class="mensaje-pendientes">✅ Turnos pendientes</span>
    }
</div
<br />
<!-- 📌 TABLA COMPLETA (para pantallas grandes) -->
<RadzenColumn class="tabla-grande" Size="12" style="width: 100%; margin-bottom: 4rem; border-radius: 10px; background: #f9f9f9;  padding: 15px;">
    <RadzenStack Gap="1.5rem">
        <RadzenDataGrid @ref="turnosGrid"
        AllowFiltering="false"
        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
        AllowPaging="true"
        PageSize="5"
        AllowSorting="true"
        Data="@turnos"
        TItem="Turno"                                                
        EmptyText="📭 No hay turnos disponibles"
        Style="width: 100%; max-width: 100%; border-radius: 10px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15); padding: 10px;">
            <Columns >
                <RadzenDataGridColumn Property="NombrePaciente" Title="Nombre" Width="130px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.NombrePaciente" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="ApellidoPaciente" Title="Apellido" Width="130px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.ApellidoPaciente" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn  Property="Dni" Title="DNI" Width="110px">
                    <EditTemplate Context="shift">
                        <RadzenNumeric TValue="int?" @bind-Value="shift.Dni" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="Medico" Title="Médico" Width="80px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.Medico" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="FechaTurno" Filterable="false" SortOrder="SortOrder.Ascending"  TextAlign="TextAlign.Center" Title="Fecha" Width="120px">
                    <Template Context="shift">
                        📅 @shift.FechaTurno?.ToString("dd/MM/yyyy")
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="HoraTurno" TextAlign="TextAlign.Center" Title="Hora" Width="80px">
                    <Template Context="shift">
                        🕒 @shift.HoraTurno
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Title="Notas" Width="80px">
                    <Template Context="shift">
                        @if (!string.IsNullOrEmpty(shift.Notas))
                        {
                            <RadzenButton Click="() => VerNotas(shift.Notas)" Text="📝 Ver" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Title="PDF" Width="80px">
                    <Template Context="shift">
                        @if (shift.TienePdf)
                        {
                            <RadzenButton Click="() => VerPDF(shift.Id)" Text="📄 Ver" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" TextAlign="TextAlign.Left" Width="110px">
                    <Template Context="shift">
                        @if (!shift.Cancelado)
                        {
                            <div style="display: flex; gap: 5px;">
        
                                <!-- ✅ Confirmar -->
                                @if (!shift.Confirmado)
                                {
                                    <RadzenButton Icon="check"
                                                    ButtonStyle="ButtonStyle.Success"
                                                    Size="ButtonSize.Small"
                                                    Click="() => ConfirmarTurnoUI(shift)" />
                                }

                                <!-- ❌ Cancelar -->
                                <RadzenButton Icon="delete"
                                                ButtonStyle="ButtonStyle.Danger"
                                                Size="ButtonSize.Small"
                                                Click="() => DeleteRow(shift)" />
                            </div>
                        }
                        else
                        {
                            <RadzenButton Click="() => VerMotivo(shift.MotivoCancelacion)" Text="📌 Motivo" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
</RadzenColumn>


<!-- 📌 TABLA COMPACTA (para pantallas pequeñas) -->
<RadzenColumn Size="12" class="tabla-pequena" style="width: 100%; margin-bottom: 14rem; border-radius: 10px; background: #f9f9f9; padding: 5px;">
    <RadzenStack Gap="1.5rem">
        <RadzenDataGrid AllowPaging="true"
        PageSize="5"
        AllowSorting="true"
        Data="@turnos"
        TItem="Turno"
        EmptyText="📭 No hay turnos disponibles"
        Style="width: 100%; max-width: 100%; border-radius: 10px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15); padding: 10px;">
            <Columns>
                <RadzenDataGridColumn Property="Medico" Title="Médico" Width="95px" />

                <RadzenDataGridColumn Property="FechaTurno" SortOrder="SortOrder.Ascending"  Title="Fecha" Width="85px">
                    <Template Context="shift">
                        @shift.FechaTurno?.ToString("dd/MM")
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="HoraTurno" Title="Hora" Width="67px" />

                <RadzenDataGridColumn Context="shift" Filterable="false"  Title="" Sortable="false" TextAlign="TextAlign.Left" Width="110px">
                    <Template Context="shift">
                        @if (!shift.Cancelado)
                        {
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="() => DeleteRow(shift)" />
                        }
                        else
                        {
                            <RadzenButton Click="() => VerMotivo(shift.MotivoCancelacion)" Text="📌Ver" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
</RadzenColumn>


@code
{

    bool mostrarCancelados;

    Turno turno = new Turno() { };

    RadzenDataGrid<Turno> turnosGrid;

    IEnumerable<Turno> turnos;

    private string userEmail = "";
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            userEmail = user.FindFirst(c => c.Type == ClaimTypes.Email)?.Value ?? "Email no encontrado";
        }

    }

    private bool firstRender = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (this.firstRender) // ✅ Usamos la variable de instancia
        {
            await ReloadGrid();
            this.firstRender = false; // ✅ Asegurar que solo se ejecute una vez
            StateHasChanged(); // 🔄 Forzar render para reflejar cambios en la UI
        }
    }


    async Task DeleteRow(Turno shift)
    {
        var result = await DialogService.OpenAsync("Atención", ds =>
    @<RadzenStack Gap="1.5rem" Style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; text-align: center;">
        <p><RadzenIcon Icon="warning" Style="color: #dc3545; margin-right: 5px;" /> Estás a punto de cancelar el turno:</p>
        <p><RadzenIcon Icon="event" Style="margin-right: 5px;" /> Día: <b>@shift.FechaTurno?.ToString("dd/MM/yyyy")</b></p>
        <p><RadzenIcon Icon="schedule" Style="margin-right: 5px;" /> Hora: <b>@shift.HoraTurno</b></p>
        <p><RadzenIcon Icon="person" Style="margin-right: 5px;" /> Médico: <b>@shift.Medico</b></p>

        <p><b>¿Desea continuar?</b></p>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center">
            <RadzenButton Text="Confirmar" Icon="check" ButtonStyle="ButtonStyle.Danger" Click="@(args => CancelarTurno(shift.Id, shift))" />
            <RadzenButton Text="Cancelar" Icon="close" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
        </RadzenStack>
    </RadzenStack>
    );
    }

    async Task ConfirmarTurnoUI(Turno turno)
    {
        string query = "UPDATE turnos SET confirmado=true WHERE idTurno=@idTurno";

        var parametros = new Dictionary<string, object>
        {
            { "@idTurno", turno.Id }
        };

        int result = Base.InsertDeleteOrUpdateABase(query, parametros);

        if (result > 0)
        {
            // 🔁 actualizar estado en memoria (clave)
            turno.ConfirmadoManual = true;

            // 📧 email
            if (!string.IsNullOrEmpty(turno.Email))
            {
                try
                {
                    EmailService emailService = new EmailService();

                    string cuerpo = $"Su turno del {turno.FechaTurno:dd/MM/yyyy} a las {turno.HoraTurno} ha sido confirmado.";

                    await emailService.EnviarCorreoAsync(
                        turno.Email,
                        "Confirmación de turno",
                        cuerpo
                    );
                }
                catch (Exception ex)
                {
                    Log.Error(ex, "Error enviando email confirmación");
                }
            }

            // 📱 WhatsApp (opcional pero recomendable)
            if (!string.IsNullOrEmpty(turno.Telefono))
            {
                try
                {
                    var whatsappService = new WhatsAppService();

                    var contentSid = "HXd4aab42177e1533334d10f9ca240170c"; // <- SID real de confirmacion_turno

                    var variables = new Dictionary<string, string>
                        {
                        { "1", turno.NombrePaciente },
                        { "2", turno.Medico },
                        { "3", turno.FechaTurno?.ToString("dd/MM/yyyy") ?? "" },
                        { "4", turno.HoraTurno }
                        };

                    whatsappService.EnviarMensajePlantilla(turno.Telefono, contentSid, variables);

                }
                catch (Exception ex)
                {
                    Log.Error(ex, "Error enviando WhatsApp confirmación");
                }
            }

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Turno confirmado",
                Detail = "Confirmación realizada correctamente"
            });

            StateHasChanged(); // 👈 NO hace falta reload completo
        }
    }


    async Task VerPDF(int idTurno)
    {
        string query = "SELECT * FROM `pdfs` WHERE idTurno = @idTurno";
        var parametros = new Dictionary<string, object> 
        {
            { "@idTurno", idTurno } 
        };

        List<Pdf> listaArchivos = Base.SelectAPDFS(query, parametros);

        var result = await DialogService.OpenAsync("Archivo adjunto", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>El turno tiene los siguientes archivos adjuntos: </p>

        @foreach(Pdf archivo in listaArchivos) 
        {
             <a href="data:application/pdf;base64,@Convert.ToBase64String(archivo.Archivo)"
               download="turno.pdf">
                @archivo.NombreArchivo
            </a>
        }
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                <RadzenStack Orientation="Orientation.Horizontal">

                    <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
    );
    }

    async Task CancelarTurno(int idABorrar, Turno turno)
{
    string query = "UPDATE `turnos` SET cancelado=true, motivoCancelacion='Cancelado por el usuario' WHERE idTurno=@idTurno;";
    var parametros = new Dictionary<string, object> { { "@idTurno", idABorrar } };

    int cambiarEstado = Base.InsertDeleteOrUpdateABase(query, parametros);
    if (cambiarEstado > 0)
    {
        // ✅ Enviar email
        if (!string.IsNullOrEmpty(turno.Email))
        {
            try
            {
                EmailService emailService = new EmailService();
                string cuerpo = $"Estimado/a: <br><br> Su turno del día: <b>{turno.FechaTurno?.ToString("dd-MM-yyyy")}</b> a las: <b>{turno.HoraTurno}</b> hs ha sido <b>cancelado</b> correctamente.<br><br>Muchas gracias.<br>Consultorio Médico.";
                await emailService.EnviarCorreoAsync(turno.Email, "Cancelación de turno", cuerpo);
                Console.WriteLine("📧 Email enviado por cancelación");
            }
            catch (Exception ex)
            {
                Log.Error(ex, "❌ Error al enviar el email");
            }
        }

        // ✅ Enviar WhatsApp
        if (!string.IsNullOrEmpty(turno.Telefono))
        {
            try
            {
                var whatsappService = new WhatsAppService();
                string sidPlantilla = "HX889eb4920b0d442f01b901f35ed600c6"; // Cancelacion de turno

                var variables = new Dictionary<string, string>
                {
                    { "1", turno.NombrePaciente },
                    { "2", turno.FechaTurno?.ToString("dd/MM/yyyy") ?? "" },
                    { "3", turno.HoraTurno }
                };

                whatsappService.EnviarMensajePlantilla(turno.Telefono, sidPlantilla, variables);
                Console.WriteLine("📱 WhatsApp enviado por cancelación");
            }
            catch (Exception ex)
            {
                Log.Error(ex, "❌ Error al enviar WhatsApp");
            }
        }

        DialogService.Close();
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Info,
            Summary = "Turno cancelado",
            Detail = "Notificaciones enviadas correctamente"
        });

        await ReloadGrid();
    }
    else
    {
        Console.WriteLine("❌ Error al actualizar la base de datos al cancelar el turno");
    }
}


    async Task OnMostrarCanceladosChange(bool value)
    {
        mostrarCancelados = value;  // Actualiza la variable
        await ReloadGrid();         // Llama a ReloadGrid() correctamente
    }

    async Task ReloadGrid()
    {
        string query = "SELECT * FROM turnos WHERE email=@email AND cancelado=@cancelado";

        var parametros = new Dictionary<string, object>
            {
            { "@email", userEmail },
            { "@cancelado", mostrarCancelados }
            };
        
        turnos = Base.SelectATurnos(query,parametros);

        await turnosGrid.Reload();

    }

    async Task VerNotas(string nota)
    {
        var result = await DialogService.OpenAsync("Notas adjuntas", ds =>
        @<RadzenStack Gap="1.5rem">
            <p><b>El turno tiene la siguiente nota:</b></p>
            <p> @nota </p>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
        );

    }

    
    async Task VerMotivo(string motivo)
    {
        var result = await DialogService.OpenAsync("Motivo:", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>El turno tiene el siguiente motivo de cancelación:</p>
        <p> @motivo </p>
        
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenStack Orientation="Orientation.Horizontal">
                <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>
    );

    }

    
    private void EditarTurno(int id)
    {
        Navigation.NavigateTo($"/editarturno/{id}");
    }
}

