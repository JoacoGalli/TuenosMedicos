@page "/listarturnos"

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

@inject DialogService DialogService
@inject NavigationManager Navigation
@inject DialogService DialogService
@inject NotificationService NotificationService


<PageTitle>Listado de turnos reservados</PageTitle>


<h2 style="text-align: center; margin-top: 1rem; margin-bottom: 1rem;">Listado de turnos reservados</h2>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem" class="rz-p-sm-12" Style="width: 100%;">
    <!-- Selección de Médico -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenLabel Text="Seleccionar médico" Component="DropDownBindValue" />
        <RadzenDropDown @bind-Value="medicoSeleccionado" Placeholder="Seleccionar" Data="@listaMedicos" Change="@OnMedicoSeleccionado"
                        Style="width: 250px;" TextProperty="NombreMedico" ValueProperty="NombreMedico" Name="Medico">
            <RadzenRequiredValidator Component="Medico" Text="Debes seleccionar un médico" />
        </RadzenDropDown>
    </RadzenStack>

    <!-- Checkbox de Cancelados -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenCheckBox @bind-Value="mostrarCancelados" TValue="bool" Change="@OnMostrarCanceladosChange" Name="ButtonMostrarCancelados" />
        <RadzenLabel Text="Mostrar cancelados" Component="ButtonMostrarCancelados" class="rz-ms-2" />
    </RadzenStack>

    <!-- Mensaje dinámico -->
    <RadzenLabel class="mensaje-turnos" Style="font-size: 1.1rem; font-weight: bold;">
        @if (mostrarCancelados)
        {
            <span style="color: red;">❌ Turnos cancelados</span>
        }
        else
        {
            <span style="color: green;">✅ Turnos pendientes</span>
        }
    </RadzenLabel>
</RadzenStack>


<RadzenColumn Size="12" class="rz-p-2" Style="width: 100%; margin-bottom: 4rem;">
    <RadzenStack Gap="1.5rem">
        <RadzenDataGrid @ref="turnosGrid"
                        AllowFiltering="true"
                        FilterMode="FilterMode.Simple"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="true"
                        PageSize="10"
                        AllowSorting="true"
                        Data="@turnos"
                        TItem="Turno"
                        ColumnWidth="200px"
                        EmptyText="📭 No hay turnos para mostrar"
                        Style="width: 1500px; margin-left:-15%; border-radius: 8px; box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);">
            <Columns>
                <RadzenDataGridColumn Property="NombrePaciente" Title="Nombre" Width="120px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.NombrePaciente" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="ApellidoPaciente" Title="Apellido" Width="120px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.ApellidoPaciente" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="Dni" Title="DNI" Width="100px">
                    <EditTemplate Context="shift">
                        <RadzenNumeric TValue="int?" @bind-Value="shift.Dni" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="Cobertura" Title="Cobertura" Width="120px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.Cobertura" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="Medico" Title="Médico" Width="120px">
                    <EditTemplate Context="shift">
                        <RadzenTextBox @bind-Value="shift.Medico" Style="width: 100%; border-radius: 5px;" />
                    </EditTemplate>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="FechaTurno" Title="Fecha" Width="100px" SortOrder="SortOrder.Ascending" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        📅 @shift.FechaTurno?.ToString("dd/MM/yyyy")
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="HoraTurno" Title="Hora" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        🕒 @shift.HoraTurno
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" Title="Notas" Width="60px" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        @if (!string.IsNullOrEmpty(shift.Notas))
                        {
                            <RadzenButton Click=@(args => VerNotas(shift.Notas))
                                          Text="📝 Ver"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Info" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" Title="PDF" Width="60px" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        @if (shift.DocumentoPDF != null)
                        {
                            <RadzenButton Click=@(args => VerPDF(shift.DocumentoPDF))
                                          Text="📄 Ver"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Info" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" Title="N.Int" Width="60px" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        @if (!string.IsNullOrEmpty(shift.NotasInternas))
                        {
                            <RadzenButton Click=@(args => VerNotas(shift.NotasInternas))
                                          Text="📌 Ver"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Info" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" Title="Contacto" Width="65px" TextAlign="TextAlign.Center">
                    <Template Context="shift">
                        <RadzenButton Click=@(args => VerContacto(shift.NombrePaciente,shift.ApellidoPaciente,shift.Telefono,shift.Email,shift.Domicilio, shift.NumeroAfiliado, shift.CategoriaAfiliado))
                                      Text="📞 Ver"
                                      Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Light" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Context="shift" Filterable="false" Sortable="false" TextAlign="TextAlign.Left" Width="90px">
                    <Template Context="shift">
                        @if (!shift.Cancelado)
                        {
                            <RadzenButton Icon="build"
                                          ButtonStyle="ButtonStyle.Success"
                                          Size="ButtonSize.Small"
                                          Click="@(args => EditarTurno(shift.Id))" />
                            <RadzenButton Icon="delete"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Size="ButtonSize.Small"
                                          Click="@(args => DeleteRow(shift))" />
                        }
                        else
                        {
                            <RadzenButton Click=@(args => VerMotivo(shift.NombrePaciente,shift.ApellidoPaciente,shift.MotivoCancelacion))
                                          Text="📌 Motivo"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
</RadzenColumn>




@code
{
    string medicoSeleccionado = "";
    List<Medico> listaMedicos = Medico.ObtenerMedicos();

    bool mostrarCancelados;

    Turno turno = new Turno() { };

    RadzenDataGrid<Turno> turnosGrid;

    IEnumerable<Turno> turnos;

    protected override async Task OnInitializedAsync()
    {
        listaMedicos.Add(new Medico() { NombreMedico = "Todos" });
    }

    private bool firstRender = true;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (this.firstRender) // ✅ Usamos la variable de instancia
        {
            await ReloadGrid();
            this.firstRender = false; // ✅ Asegurar que solo se ejecute una vez
            StateHasChanged(); // 🔄 Forzar render para reflejar cambios en la UI
        }
    }

    private void OnMedicoSeleccionado(object value)
    {
        ReloadGrid();
    }
    async Task OnMostrarCanceladosChange(bool value)
    {
        mostrarCancelados = value;  // Actualiza la variable
        await ReloadGrid();         // Llama a ReloadGrid() correctamente
    }

    async Task DeleteRow(Turno shift)
    {
        var result = await DialogService.OpenAsync("Atención", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>Estás a punto de cancelar el turno de : <b>@shift.NombrePaciente @shift.ApellidoPaciente</b></p>
        <p>Día:  <b>@shift.FechaTurno?.ToString("dd/MM/yyyy") </b></p>
        <p>Hora:  <b>@shift.HoraTurno </b></p>
        <p>Médico:  <b>@shift.Medico </b></p>

        <p><b>¿Desea continuar? </b></p>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenButton Text="Confirmar" Click="@(args => CancelarTurno(shift.Id))" />
                    <RadzenButton Text="Cancelar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
    );
    }

    async Task VerPDF(byte[] pdf)
    {
        var result = await DialogService.OpenAsync("Archivo adjunto", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>El turno tiene el siguiente archivo adjunto: </p>

        <a href="data:application/pdf;base64,@Convert.ToBase64String(pdf)"
           download="turno.pdf">
            Descargar PDF
        </a>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                <RadzenStack Orientation="Orientation.Horizontal">

                    <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
    );
    }

    void CancelarTurno(int idABorrar)
    {
        string query = "UPDATE `turnos-medicos`.`turnos` SET cancelado=true,motivoCancelacion='Cancelado por admin desde Listado de turnos' WHERE idTurno=@idTurno;"; 
        var parametros = new Dictionary<string, object> { { "@idTurno", idABorrar } };

        int cambiarEstado = Base.InsertDeleteOrUpdateABase(query,parametros);
        if (cambiarEstado > 0)
        {
            DialogService.Close(); // Cierra el diálogo
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "OK", Detail = "Turno cancelado" });
            ReloadGrid();
        }
        else
        {
            Console.WriteLine("error cancelando el turno");
        }
    }

    async Task ReloadGrid()
    {
        string query = "SELECT * FROM `turnos-medicos`.turnos WHERE cancelado=@cancelado";
        var parametros = new Dictionary<string, object>
                    {
                        { "@cancelado", mostrarCancelados }
                    };


        if (!string.IsNullOrEmpty(medicoSeleccionado) &&  medicoSeleccionado!="Todos" )
        {

            query = query + " AND medico=@medico";
            parametros = new Dictionary<string, object>
                        {
                        { "@cancelado", mostrarCancelados },
                         { "@medico", medicoSeleccionado }
                        };
            
        }
        turnos = Base.SelectATurnos(query,parametros);

        await turnosGrid.Reload();

    }

    async Task VerNotas(string nota)
    {
        var result = await DialogService.OpenAsync("Nota adjunta", ds =>
        @<RadzenStack Gap="1.5rem">
            <p><b>El turno tiene la siguiente nota:</b></p>
            <p> @nota </p>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
        );

    }

    async Task VerContacto(string nombre, string apellido, string telefono, string email, string domicilio, string numeroAfil, string categAfil)
    {
        var result = await DialogService.OpenAsync("Datos de contacto:", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>Datos de contacto de: <b> @nombre @apellido </b></p>
            <p><b>Teléfono: </b> @telefono </p>
            <p><b>Email: </b> @email </p>

        @if(!string.IsNullOrEmpty(numeroAfil))
            {
                <p><b>Número Afiliado: </b> @numeroAfil </p>
            }
        @if(!string.IsNullOrEmpty(categAfil))
    {
        <p><b>Categoría Afiliado: </b> @categAfil </p>
    }


        @if(!string.IsNullOrEmpty(domicilio))
            {
                <p><b>Domicilio: </b> @domicilio </p>
            }   
            
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
            );

    }

    async Task VerMotivo(string nombre, string apellido, string motivo)
    {
        var result = await DialogService.OpenAsync("Motivo:", ds =>
        @<RadzenStack Gap="1.5rem">
        <p>El turno de <b>@nombre @apellido </b> tiene el siguiente motivo de cancelación:</p>
        <p> @motivo </p>
        
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenStack Orientation="Orientation.Horizontal">
                <RadzenButton Text="Cerrar" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Light" />
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>
    );

    }

    
    private void EditarTurno(int id)
    {
        Navigation.NavigateTo($"/editarturno/{id}");
    }
}

