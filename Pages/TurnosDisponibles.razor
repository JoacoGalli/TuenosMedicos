@page "/turnos_disponibles"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<PageTitle>Turnos Disponibles</PageTitle>

<h2 style="text-align: center; margin-top: 1rem;">Turnos disponibles</h2>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem" class="rz-p-sm-12 rz-text-base">

    <RadzenLabel Text="Seleccionar médico" Component="DropDownBindValue" Style="font-weight: 600;" />
    <RadzenDropDown @bind-Value="medicoSeleccionado" Placeholder="Seleccionar"
                    Data="@listaMedicos"
                    Style="width: 250px; font-size: 1rem;"
                    Change="@(async args => await OnMedicoSeleccionado(args))"
                    TextProperty="NombreMedico" ValueProperty="NombreMedico" />

        <!-- Checkbox de Visualizar Sobre Turnos -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenCheckBox @bind-Value="mostrarSobreTurnos" TValue="bool" Change="@(async _ => await OnMedicoSeleccionado(medicoSeleccionado))" Name="ButtonMostrarSobreTurnos" />
        <RadzenLabel Text="Mostrar sobre turnos" Component="ButtonMostrarSobreTurnos" class="rz-ms-2" />
    </RadzenStack>

    <RadzenText Style="font-size: 1rem;">
        <a href=@rutaConProximoTurno style="text-decoration: none; font-weight: 500; color: #007bff;">Reservar próximo turno:</a>
        <span style="margin-left: 0.5rem;"><b>@proximoTurno</b></span>
    </RadzenText>

</RadzenStack>


@if (turnosVisuales?.Any() == true)
{
    <RadzenScheduler @ref=@calendario TItem="TurnoVisual" Data="@turnosVisuales"
    StartProperty="FechaHora" EndProperty="FechaHora" AppointmentSelect=@OnAppointmentSelect AppointmentRender=@OnAppointmentRender SlotRender="@(args => OnSlotRender(args))"
    TextProperty="Texto" style="height: 768px;">
        <RadzenMonthView />
    </RadzenScheduler>


}

@code {
    public class TurnoVisual
    {
        public DateTime FechaHora { get; set; }
        public string Texto { get; set; }
        //=> FechaHora.ToString("HH:mm");

        public string Medico { get; set; } = "";
        public bool SobreTurno { get; set; }
    }

    RadzenScheduler<TurnoVisual> calendario;
    string? medicoSeleccionado;
    List<TurnoVisual> turnosVisuales = new();
    List<TurnoVisual> listaTurnos = new();
    List<Medico> listaMedicos = Medico.ObtenerMedicos();
    string rutaConProximoTurno;
    string proximoTurno;
    bool mostrarSobreTurnos = false; // false por defecto, solo muestra turnos comunes

    private async Task OnMedicoSeleccionado(object value)
    {
        medicoSeleccionado = value?.ToString();
        if (!string.IsNullOrEmpty(medicoSeleccionado))
        {
            await GenerarTurnosParaTodoElAño();
            StateHasChanged();
            await calendario.Reload();
        }
    }

    private async Task GenerarTurnosParaTodoElAño()
    {
        turnosVisuales.Clear();

        List<Medico> horariosMedicos = Base.SelectAMedicos("SELECT * FROM medicos");


        // 1. Obtener fechas bloqueadas del médico seleccionado
        string query = "SELECT * FROM medicos_fechas_bloqueadas WHERE nombreMedico = @nombreMedico";
        var parametros = new Dictionary<string, object> { { "@nombreMedico", medicoSeleccionado } };

        List<MedicoFechaBloqueada> fechasBloqueadasFull = Base.SelectAMedicosFechasBloqueadas(query, parametros);
        List<DateTime> fechasBloqueadas = fechasBloqueadasFull
            .Select(f => f.FechaBloqueada.Date) // Nos quedamos solo con la parte de la fecha
            .ToList();

        DateTime hoy = DateTime.Today;
        bool primerMesFor = true;       //Lo uso como bandera para completar el primer mes partiendo desde hoy y no desde el 1.
        for (int i = 0; i < 12; i++)        //Recorremos los meses
        {
            var fechaBase = hoy.AddMonths(i);
            int año = fechaBase.Year;
            int mes = fechaBase.Month;
            int diasEnElMes = DateTime.DaysInMonth(año, mes);


            int diaInicialFor = 1;          //Arranca desde el 1ro de cada mes a excepcion del mes actual.
            if (primerMesFor)
            {
                diaInicialFor = hoy.Day;
            }


            for (int dia = diaInicialFor; dia <= diasEnElMes; dia++)        //Recorremos los dias de cada mes
            {

                var fecha = new DateTime(año, mes, dia);

                // 2. Si la fecha está bloqueada, la salteamos
                if (fechasBloqueadas.Contains(fecha.Date))
                    continue;

                var turno = new Turno
                    {
                        Medico = medicoSeleccionado,
                        FechaTurno = fecha
                    };

                string nombreDiaEnEspañol = fecha.DayOfWeek switch
                {
                    DayOfWeek.Monday => "Lunes",
                    DayOfWeek.Tuesday => "Martes",
                    DayOfWeek.Wednesday => "Miercoles",
                    DayOfWeek.Thursday => "Jueves",
                    DayOfWeek.Friday => "Viernes",
                    DayOfWeek.Saturday => "Sabado",
                    DayOfWeek.Sunday => "Domingo",
                    _ => "Desconocido"
                };

                foreach (Medico med in horariosMedicos)
                {
                    if (med.NombreMedico == medicoSeleccionado && med.diaTrabajo == nombreDiaEnEspañol)
                    {

                        TimeSpan horaInicio = TimeSpan.Parse(med.horaInicioTrabajo);
                        TimeSpan horaFin = TimeSpan.Parse(med.horaFinTrabajo);

                        var horarios = turno.ObtenerHorariosDisponibles(true);
                        foreach (var h in horarios)
                        {
                            if (DateTime.TryParseExact(h, "HH:mm", null, System.Globalization.DateTimeStyles.None, out var hora))
                            {
                                var fechaHora = new DateTime(fecha.Year, fecha.Month, fecha.Day, hora.Hour, hora.Minute, 0);

                                bool esSobreTurno = false;
                                string textoAcolocar = fechaHora.ToString("HH:mm");
                                if (hora.TimeOfDay < horaInicio || hora.TimeOfDay > horaFin )
                                {
                                    esSobreTurno = true;
                                    textoAcolocar = textoAcolocar + " - Sobreturno";
                                }

                                listaTurnos.Add(new TurnoVisual
                                    {
                                        FechaHora = fechaHora,
                                        Texto = textoAcolocar,
                                        Medico = medicoSeleccionado,
                                        SobreTurno = esSobreTurno
                                    });
                            }
                        }
                    }
                }
            }
            primerMesFor = false;
        }

        // Filtrar según el checkbox
        turnosVisuales = mostrarSobreTurnos
            ? listaTurnos
            : listaTurnos.Where(t => !t.SobreTurno).ToList();

        // Buscar el próximo turno no sobreturno
        TurnoVisual proxTurno = turnosVisuales.FirstOrDefault(t => t.SobreTurno == false);

        if (proxTurno == null)
        {
            Console.WriteLine("No se encontró un turno que no sea sobreturno.");
            return;
        }

        proximoTurno = proxTurno.FechaHora.ToString("dd/MM/yyyy HH:mm");

        string fechalink = proxTurno.FechaHora.ToString("dd-MM-yyyy");
        string horalink = proxTurno.FechaHora.ToString("HH:mm");
        rutaConProximoTurno = $"/reservarturno/{proxTurno.Medico}/{fechalink}/{horalink}";
    }


    void OnSlotRender(SchedulerSlotRenderEventArgs args)
    {

        //Pinta el dia de hoy
        if (args.View.Text == "Month" && args.Start.Date == DateTime.Today)
        {
            args.Attributes["style"] = "background: var(--rz-scheduler-highlight-background-color, rgba(255,220,40,.2));";
        }


    }

    async Task OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<TurnoVisual> args)
    {

        string medico = args.Data.Medico;
        string fecha = args.Data.FechaHora.ToString("dd-MM-yyyy");
        string hora = args.Data.FechaHora.ToString("HH:mm");

        Navigation.NavigateTo($"reservarturno/{medico}/{fecha}/{hora}");
    }

    void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<TurnoVisual> args)
    {
        if (args.Data.SobreTurno)
        {
        
            args.Attributes["style"] = "background: #F08080; color: white; border-radius: 6px; padding: 2px 6px; font-weight: bold; font-family: 'Segoe UI', sans-serif; letter-spacing: 0.5px; font-size: 16px;";
        }
        else
        {
            args.Attributes["style"] = "background: #A8E6CF; color: #2A5D5E; border-radius: 6px; padding: 2px 6px; font-weight: 500; font-family: 'Segoe UI', sans-serif; letter-spacing: 0.5px; font-size: 16px;";



        }
    }

}
