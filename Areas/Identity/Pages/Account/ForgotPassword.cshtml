@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "¿Olvidaste tu contraseña?";
}

<h1 class="reset-title">@ViewData["Title"]</h1>
<h2 class="text-center">Ingresa tu correo electrónico</h2>
<p class="text-center text-muted">Te enviaremos un enlace para restablecer tu contraseña.</p>
<hr />

<div class="row justify-content-center">
    <div class="col-md-6">
        <form method="post" class="reset-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">Correo Electrónico</label>
                <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <br />
            <button type="submit" class="btn btn-primary btn-lg btn-block reset-button">
                <i class="fa fa-envelope"></i> Enviar enlace
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
